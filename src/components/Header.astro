---
/**
 * Header（頁首：LOGO + 桌機導覽 + 手機漢堡選單）
 * ─────────────────────────────────────────────────
 * 顯示位置：每一頁最上方
 *
 * 三段斷點行為：
 *   ▸ Desktop > 960px → LOGO + 雙語字樣 + 完整導覽 + CTA 全部顯示
 *   ▸ Tablet ≤ 960px  → 隱藏 desktop 導覽 + 雙語字樣，改顯示漢堡按鈕
 *   ▸ Mobile ≤ 640px  → LOGO 再縮小、邊距收緊
 *
 * 漢堡選單行為：
 *   ▸ 點漢堡按鈕 → 全屏 linen 覆蓋層淡入 + 選項由上而下 stagger 進場
 *   ▸ 點任一連結 / 按 ESC → 關閉
 *   ▸ 開啟時 body 鎖捲動
 *
 * 怎麼設定：
 *   ▸ 改 LOGO 大小 → 改下方 <Wordmark size={190} />（手機端會自動縮）
 *   ▸ 加/減/改導覽連結 → 改下方 links 陣列；mobile menu 自動同步
 *   ▸ 改漢堡顯示斷點 → 改 @media (max-width: 960px) 的數字
 *   ▸ 改 mobile menu 背景色 → .sf-mobile-menu { background: var(--linen) }
 *   ▸ 改 mobile 選項字體大小 → .sf-mobile-menu__en { font-size: 32px }
 */
import Wordmark from './Wordmark.astro';

interface Props { active?: string; }
const { active } = Astro.props;

// 主導覽連結：[顯示英文, 顯示中文, 連結網址]
// 想加項目就 push 一筆；中文是給使用者看的，英文是 active 高亮 key。
// （/atelier、/installation、/wedding、/seasonal 仍可從頁尾或直接網址訪問）
const links: Array<[string, string, string]> = [
  ['News',    '最新消息',  `${import.meta.env.BASE_URL}`],
  ['Works',   '作品瀏覽',  `${import.meta.env.BASE_URL}works`],
  ['Shop',    '線上購物',  `${import.meta.env.BASE_URL}shop`],
  ['Contact', '聯絡我們', `${import.meta.env.BASE_URL}enquiry`],
];
---
<header class="sf-header">
  <span class="sf-header__brand">
    <Wordmark size={200} />
    <span class="sf-header__lockup" aria-hidden="true">
      <span class="sf-header__lockup-tc">靜謐花間</span>
      <span class="sf-header__lockup-en">SERENITY FLOWER</span>
    </span>
  </span>

  <nav class="sf-header__nav" aria-label="Primary">
    {links.map(([en, tc, href]) => (
      <a href={href} class:list={['sf-navlink', active === en && 'is-active']}>
        <span class="sf-navlink__en">{en}</span>
        <span class="sf-navlink__tc">{tc}</span>
      </a>
    ))}
  </nav>

  <a href={`${import.meta.env.BASE_URL}enquiry`} class="sf-header__cta">Reserve a date <span aria-hidden="true">→</span></a>

  <button
    class="sf-burger"
    type="button"
    aria-label="開啟選單 · Open menu"
    aria-expanded="false"
    aria-controls="sf-mobile-menu"
  >
    <span class="sf-burger__line" aria-hidden="true"></span>
    <span class="sf-burger__line" aria-hidden="true"></span>
    <span class="sf-burger__line" aria-hidden="true"></span>
  </button>
</header>

<div
  id="sf-mobile-menu"
  class="sf-mobile-menu"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="主選單"
  inert
>
  <div class="sf-mobile-menu__inner">
    <span class="sf-mobile-menu__eyebrow">
      <span class="sf-mobile-menu__rule"></span>
      <span>Menu · 選單</span>
    </span>
    <nav class="sf-mobile-menu__nav" aria-label="Mobile primary">
      {links.map(([en, tc, href], i) => (
        <a
          href={href}
          class:list={['sf-mobile-menu__link', active === en && 'is-active']}
          style={`--i:${i}`}
        >
          <span class="sf-mobile-menu__en">{en}</span>
          <span class="sf-mobile-menu__tc">{tc}</span>
          <span class="sf-mobile-menu__arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>
    <div class="sf-mobile-menu__foot">
      <a href={`${import.meta.env.BASE_URL}enquiry`} class="sf-mobile-menu__cta">
        Reserve a date · 預約 <span aria-hidden="true">→</span>
      </a>
      <p class="sf-mobile-menu__tagline">
        Stillness, restructured.<br/>靜謐，重構。
      </p>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const burger = document.querySelector('.sf-burger');
    const menu = document.getElementById('sf-mobile-menu');
    if (!burger || !menu) return;

    const setOpen = (open) => {
      burger.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
      // inert 屬性：關閉時阻擋鍵盤 Tab 焦點進入隱藏選單（a11y 必備）
      if (open) menu.removeAttribute('inert');
      else menu.setAttribute('inert', '');
      document.documentElement.classList.toggle('menu-open', open);
      document.body.style.overflow = open ? 'hidden' : '';
      // 開啟時自動聚焦第一個連結，方便鍵盤使用者
      if (open) {
        const first = menu.querySelector('a');
        if (first) setTimeout(() => first.focus(), 300);
      }
    };

    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    menu.addEventListener('click', (e) => {
      if (e.target.closest('a')) setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        burger.focus();
      }
    });

    // 視窗放大跨過斷點時自動關閉
    const mql = window.matchMedia('(min-width: 961px)');
    mql.addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  })();
</script>

<style>
  /* ─── Header bar ─────────────────────────────────────── */
  .sf-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 32px;
    padding: 28px 0 24px;
    border-bottom: 1px solid var(--ink-10);
  }
  .sf-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    background-image: none;
    line-height: 1;
  }
  .sf-header__brand :global(.sf-wordmark) { display: inline-flex; }
  .sf-header__lockup {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 14px;
    border-left: 1px solid var(--ink-20);
  }
  .sf-header__lockup-tc {
    font-family: var(--font-display-tc);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--ink);
    line-height: 1.05;
  }
  .sf-header__lockup-en {
    font-family: var(--font-display-en);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-70);
    line-height: 1;
  }

  /* ─── Desktop nav ────────────────────────────────────── */
  .sf-header__nav {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .sf-navlink {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    position: relative; padding-bottom: 6px;
    background-image: none;
    background: none;
  }
  .sf-navlink__en {
    font-family: var(--font-body-en);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .sf-navlink__tc {
    font-family: var(--font-body-tc);
    font-size: 11px;                /* 10→11：行動裝置最低字級避免讀屏壓迫 */
    color: var(--ink-70);           /* ink-40→ink-70：對比達 WCAG AA */
    letter-spacing: 0.25em;
  }
  .sf-navlink::after {
    content: '';
    position: absolute; left: 0; bottom: 0;
    width: 0; height: 1px;
    background: var(--ink);
    transition: width 0.2s ease;
  }
  .sf-navlink:hover::after { width: 100%; }
  .sf-navlink.is-active::after { width: 100%; height: 2px; background: var(--bark); }

  /* ─── Desktop CTA ────────────────────────────────────── */
  .sf-header__cta {
    font-family: var(--font-body-en);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    background-image: linear-gradient(var(--ink), var(--ink));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0 1px;
    padding-bottom: 4px;
    transition: background-size 0.2s ease;
    white-space: nowrap;
  }
  .sf-header__cta:hover { background-size: 100% 1px; }

  /* ─── Hamburger button（≤960px 才顯示）───────────────
     合規重點：
     - 觸控區 ≥ 44×44px（WCAG / Apple HIG / Material 標準）
     - 視覺線條 28×18px 置中於觸控區內，視覺輕巧、手指接觸範圍寬鬆
     - 鍵盤 :focus-visible 顯示 bark 外框
  */
  .sf-burger {
    display: none;
    width: 44px;                 /* 觸控區 44px ✓ */
    height: 44px;                /* 觸控區 44px ✓ */
    background: transparent;
    background-image: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    position: relative;
    z-index: 201;
  }
  .sf-burger__line {
    position: absolute;
    left: 8px;                   /* (44-28)/2 = 8 → 線條寬 28px 置中 */
    right: 8px;
    height: 1px;
    background: var(--ink);
    transition: transform 0.3s var(--ease-stately),
                opacity 0.2s ease,
                top 0.3s var(--ease-stately);
  }
  .sf-burger__line:nth-child(1) { top: 13px; }
  .sf-burger__line:nth-child(2) { top: 50%; transform: translateY(-50%); }
  .sf-burger__line:nth-child(3) { bottom: 13px; top: auto; }

  /* 開啟時：第 1/3 條變 X，第 2 條淡出 */
  .sf-burger[aria-expanded="true"] .sf-burger__line:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  .sf-burger[aria-expanded="true"] .sf-burger__line:nth-child(2) {
    opacity: 0;
  }
  .sf-burger[aria-expanded="true"] .sf-burger__line:nth-child(3) {
    top: 50%;
    bottom: auto;
    transform: translateY(-50%) rotate(-45deg);
  }

  /* ─── Mobile menu overlay ─────────────────────────── */
  .sf-mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--linen);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    overflow-y: auto;
    transition: opacity 0.4s var(--ease-stately);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--s-9) var(--s-6);
  }
  :global(html.menu-open) .sf-mobile-menu {
    opacity: 1;
    pointer-events: auto;
  }

  .sf-mobile-menu__inner {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: var(--s-7);
  }

  .sf-mobile-menu__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-body-en);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--bark);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease-stately) 100ms,
                transform 0.4s var(--ease-stately) 100ms;
  }
  .sf-mobile-menu__rule {
    display: inline-block;
    width: 28px;
    height: 2px;
    background: var(--bark);
  }
  :global(html.menu-open) .sf-mobile-menu__eyebrow {
    opacity: 1;
    transform: translateY(0);
  }

  .sf-mobile-menu__nav {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--ink-10);
  }
  .sf-mobile-menu__link {
    padding: var(--s-5) 0;
    border-bottom: 1px solid var(--ink-10);
    background-image: none;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: var(--s-3);
    row-gap: 4px;
    align-items: center;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.45s var(--ease-stately) calc(var(--i) * 60ms + 220ms),
                transform 0.45s var(--ease-stately) calc(var(--i) * 60ms + 220ms),
                color 0.2s ease;
  }
  :global(html.menu-open) .sf-mobile-menu__link {
    opacity: 1;
    transform: translateY(0);
  }
  .sf-mobile-menu__en {
    font-family: var(--font-display-en);
    font-size: 32px;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--ink);
    grid-column: 1;
    grid-row: 1;
  }
  .sf-mobile-menu__tc {
    font-family: var(--font-display-tc);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.32em;
    color: var(--ink-70);            /* ink-40→ink-70：WCAG AA 4.5:1 */
    grid-column: 1;
    grid-row: 2;
  }
  .sf-mobile-menu__arrow {
    grid-column: 2;
    grid-row: 1 / span 2;
    font-family: var(--font-display-en);
    font-size: 22px;
    color: var(--ink-70);            /* ink-40→ink-70：箭頭也提高可見度 */
    transform: translateX(-4px);
    opacity: 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .sf-mobile-menu__link:hover .sf-mobile-menu__en,
  .sf-mobile-menu__link.is-active .sf-mobile-menu__en {
    color: var(--bark);
    font-style: italic;
  }
  .sf-mobile-menu__link:hover .sf-mobile-menu__arrow {
    transform: translateX(0);
    opacity: 1;
    color: var(--bark);
  }
  .sf-mobile-menu__link.is-active .sf-mobile-menu__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--bark);
  }

  .sf-mobile-menu__foot {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.45s var(--ease-stately) 700ms,
                transform 0.45s var(--ease-stately) 700ms;
  }
  :global(html.menu-open) .sf-mobile-menu__foot {
    opacity: 1;
    transform: translateY(0);
  }
  .sf-mobile-menu__cta {
    align-self: flex-start;
    font-family: var(--font-body-en);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--ink);
    background-image: none;
    padding: 18px 28px;
    transition: background 0.2s ease;
  }
  .sf-mobile-menu__cta:hover { background: var(--bark); }
  .sf-mobile-menu__tagline {
    font-family: var(--font-display-en);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-70);
    margin: 0;
    max-width: none;
    line-height: 1.6;
  }

  /* ─── Tablet ≤ 960px ─────────────────────────────────
     版面：三欄對稱（44px｜brand 置中｜44px hamburger）
     左側 44px 空白做為視覺平衡，讓 brand 真正在頁面中軸線上。
     參考：Aesop、Acne Studios 等編輯式品牌的對稱頁首
  */
  @media (max-width: 960px) {
    .sf-header {
      grid-template-columns: 44px 1fr 44px;   /* 對稱三欄 */
      gap: 12px;
      padding: 22px 0 20px;
      align-items: center;
    }
    .sf-header__nav,
    .sf-header__cta { display: none; }

    /* 品牌容器：放在中欄，內元素垂直堆疊並置中 */
    .sf-header__brand {
      grid-column: 2;                    /* 中欄 */
      flex-direction: column;
      align-items: center;               /* 水平置中 */
      text-align: center;
      gap: 10px;
    }
    /* lockup：平板維持橫向（靜謐花間 + SERENITY FLOWER 同列）*/
    .sf-header__lockup {
      display: inline-flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding-left: 0;
      border-left: none;
    }
    .sf-header__lockup-tc {
      font-size: 14px;
      letter-spacing: 0.22em;
    }
    .sf-header__lockup-en {
      font-size: 9px;
      letter-spacing: 0.28em;
    }

    .sf-burger {
      display: block;
      grid-column: 3;                    /* 右欄 */
      justify-self: end;
    }

    /* LOGO 在平板尺寸 140px */
    .sf-header__brand :global(.sf-wordmark img) {
      height: 140px !important;
    }
  }

  /* ─── Mobile ≤ 640px ─────────────────────────────── */
  @media (max-width: 640px) {
    .sf-header {
      padding: 18px 0 16px;
      gap: 8px;
    }
    /* 手機 LOGO 110px */
    .sf-header__brand :global(.sf-wordmark img) {
      height: 110px !important;
    }
    /* 字樣切換為直向堆疊（中文上、英文下），同樣置中 */
    .sf-header__lockup {
      flex-direction: column;
      align-items: center;               /* 直向時改置中 */
      justify-content: center;
      gap: 3px;
    }
    .sf-header__lockup-tc { font-size: 13px; letter-spacing: 0.2em; }
    .sf-header__lockup-en { font-size: 8.5px; letter-spacing: 0.26em; }

    /* mobile menu 內部排版 */
    .sf-mobile-menu {
      padding: var(--s-8) var(--s-5);
      align-items: flex-start;
      padding-top: 96px;
    }
    .sf-mobile-menu__en { font-size: 28px; }
    .sf-mobile-menu__inner { gap: var(--s-6); }
  }

  /* ─── 超小螢幕 ≤ 380px（iPhone SE 等舊機種防擠壓）─── */
  @media (max-width: 380px) {
    .sf-header__brand :global(.sf-wordmark img) {
      height: 92px !important;
    }
    .sf-header__lockup-tc { font-size: 12px; }
    .sf-header__lockup-en { font-size: 8px; }
  }
</style>
